# Online Revamp — environment variables (template)
#
# Copy this file to `.env` for local use (gitignored). For CI, set these
# as GitHub repo secrets via:
#   gh secret set VAR_NAME --repo rinaldomelo/onlinerevamp
#
# Anything ending in `_TOKEN` is a credential and must NEVER be committed.

# ──────────────────────────────────────────────────────────────────
# Shopify CLI auth (used by CI workflows for theme push commands)
# ──────────────────────────────────────────────────────────────────

# Generate via the "Theme Access" Shopify app:
#   https://apps.shopify.com/theme-access
# Select the dev store, generate a password, treat it as the value.
# Granular scopes: theme read/write only.
SHOPIFY_CLI_THEME_TOKEN=

# Store domain (no protocol). Example: online-revamp.myshopify.com
SHOPIFY_STORE_DOMAIN=

# ──────────────────────────────────────────────────────────────────
# Theme IDs per environment (find in Shopify admin URL after "themes/")
# ──────────────────────────────────────────────────────────────────

# Dev / preview theme (M4 pushes per-PR previews here)
SHOPIFY_DEV_THEME_ID=

# Staging theme (manual promotion target; not auto-deployed)
SHOPIFY_STAGING_THEME_ID=

# Production theme (M5 auto-pushes on merge to main)
SHOPIFY_PROD_THEME_ID=

# ──────────────────────────────────────────────────────────────────
# Optional — Lighthouse CI (M9 will use these if set)
# ──────────────────────────────────────────────────────────────────

# LHCI_GITHUB_APP_TOKEN=

# ──────────────────────────────────────────────────────────────────
# Optional — Anthropic API (M7+ orchestrator)
# ──────────────────────────────────────────────────────────────────

# Used by orchestrator/ when running locally. NOT used by CI workflows.
# ANTHROPIC_API_KEY=
